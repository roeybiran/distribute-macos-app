{
  "name": "@roeybiran/distribute-macos-app",
  "version": "1.1.0",
  "description": "A command line tool for distributing macOS applications",
  "type": "module",
  "bin": {
    "distribute-macos-app": "dist/index.js"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "xo",
    "prepare": "husky",
    "prepublish": "npm run build",
    "start": "npm run build && node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "macos",
    "distribution"
  ],
  "author": "Roey Biran",
  "license": "MIT",
  "dependencies": {
    "appdmg": "^0.6.0",
    "commander": "^11.1.0",
    "execa": "^9.6.0",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.5.2",
    "baseline-browser-mapping": "^2.10.12",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "typescript": "^5.9.2",
    "vitest": "^3.0.0",
    "xo": "^1.2.3"
  }
}
